  langid = {english},
  keywords = {Computer Science - Artificial Intelligence,Computer Science - Machine Learning,Computer Science - Robotics},
  file = {C:\Users\ASUS\Zotero\storage\TA66I26Q\Guan 等 - 2025 - Efficient Vision-Language-Action Models for Embodied Manipulation A Systematic Survey.pdf}
}

