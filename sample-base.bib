@misc{tang2023graspgpt,
      title={GraspGPT: Leveraging Semantic Knowledge from a Large Language Model for Task-Oriented Grasping}, 
      author={Chao Tang and Dehao Huang and Wenqi Ge and Weiyu Liu and Hong Zhang},
      year={2023},
